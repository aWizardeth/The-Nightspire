# Environment Variables Example
# Copy this to .env.local and fill in your values

# Required - Discord Application ID from Developer Portal
VITE_DISCORD_CLIENT_ID=your_application_id_here

# Required - WalletConnect/Reown Project ID for wallet connections  
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional - External service URLs (leave empty for local development)
VITE_AWIZARD_BOT_URL=
VITE_GYM_SERVER_URL=http://localhost:3001  
VITE_BOW_APP_URL=http://localhost:3000

# Feature flags
VITE_REQUIRE_NFT_GATE=false

# Token exchange endpoint (for development - auto-configured)
# VITE_TOKEN_EXCHANGE_URL=http://localhost:5173/.proxy/api/token