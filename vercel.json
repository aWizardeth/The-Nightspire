{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://discord.com https://*.discord.com https://*.discordapp.com https://*.discordsays.com"
        }
      ]
    }
  ]
}